# =============================================================================
# AlphaVision — environment template
# =============================================================================
# Copy to .env and fill secrets before first deploy:
#   cp .env.example .env
#   # edit .env (FINNHUB_API_KEY, OPENAI_API_KEY, XAI_API_URL, etc.)
#
# Or run:  ./scripts/setup-env.sh
# =============================================================================

# ── Frontend (baked into Docker image at build time) ─────────────────────────
VITE_API_URL=http://localhost:8001
VITE_GITHUB_REPO=https://github.com/GeorgeMakridis/alpha-vision-insights
VITE_CONTACT_EMAIL=legal@example.com

# ── Finnhub (required for news + market cap primary source) ──────────────────
# Free key: https://finnhub.io/dashboard
FINNHUB_API_KEY=

# ── Daily data refresh (in-container scheduler — no host cron) ───────────────
DATA_AUTO_UPDATE=true
DATA_UPDATE_HOUR=6
TZ=Europe/Athens
DATA_UPDATER_DAYS=10

# Reload in-memory API after disk updates (post_start + scheduler).
# Generate: openssl rand -hex 32
INTERNAL_RELOAD_TOKEN=

# Optional: skip background pipeline (data updater, DeepVaR) on boot
# SKIP_POST_START_TASKS=false

# Optional: re-score all news with FinBERT on boot (slow)
# DATA_REFRESH_SENTIMENT=false

# ── External XAI (on-demand headline explanations; sentiment stays FinBERT) ─
# POST {XAI_API_URL}{XAI_API_PATH}  body: { title, content, sentiment }
# Response: { limeWords: [...], aiInsights: "..." }  (snake_case also accepted)
XAI_API_URL=
XAI_API_KEY=
XAI_API_PATH=/analyze
XAI_API_TIMEOUT=30
# Local dev only when XAI_API_URL is empty (do not use in production):
XAI_USE_MOCK=true

# ── OpenAI (optional — Risk Analyst chatbot) ─────────────────────────────────
OPENAI_API_KEY=

# ── Hugging Face / FinBERT cache (recommended for Docker) ────────────────────
HF_HOME=/app/data/hf_home
# HF_TOKEN=

# ── VaR / DeepVaR tuning (defaults usually fine) ─────────────────────────────
VAR_ROLLING_WINDOW_DAYS=252
DEEPVAR_EPOCHS=10
# BLNN_VAR_API_URL=
# DEEP_VAR_API_URL=
# VAR_API_TIMEOUT=5.0

# ── Yahoo price fetch retries (when fc.yahoo.com is flaky) ───────────────────
YFINANCE_DOWNLOAD_RETRIES=5
YFINANCE_RETRY_BACKOFF_BASE_SEC=3
YFINANCE_RETRY_BACKOFF_MAX_SEC=60
YFINANCE_DOWNLOAD_THREADS=false

# ── Build provenance (optional, shown in GET /api/meta) ──────────────────────
# BUILD_SHA=
# GIT_COMMIT=
